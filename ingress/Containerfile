# Stage 1: Build Stage
FROM --platform=$BUILDPLATFORM rust:latest AS builder
WORKDIR /usr/src/echopulse

# Install build essentials and target toolchains
RUN dpkg --add-architecture ppc64el \
    && apt-get update \
    && apt-get install -y \
    gcc-x86-64-linux-gnu \
    gcc-powerpc64le-linux-gnu \
    musl-tools \
    libssl-dev \
    libssl-dev:ppc64el \
    pkg-config

COPY Cargo.toml ./
COPY src ./src

# Leverage BuildKit target platform args passed automatically by buildx
ARG TARGETPLATFORM
ARG TARGETARCH

RUN case "${TARGETARCH}" in \
        "amd64") \
            rustup target add x86_64-unknown-linux-musl && \
            export CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER=x86_64-linux-gnu-gcc && \
            cargo build --release --target x86_64-unknown-linux-musl && \
            cp target/x86_64-unknown-linux-musl/release/echopulse /usr/local/bin/echopulse ;; \
        "ppc64le") \
            rustup target add powerpc64le-unknown-linux-gnu && \
            export CARGO_TARGET_POWERPC64LE_UNKNOWN_LINUX_GNU_LINKER=powerpc64le-linux-gnu-gcc && \
            export OPENSSL_LIB_DIR=/usr/lib/powerpc64le-linux-gnu && \
            export OPENSSL_INCLUDE_DIR=/usr/include/powerpc64le-linux-gnu && \
            export PKG_CONFIG_ALLOW_CROSS=1 && \
            export PKG_CONFIG_PATH=/usr/lib/powerpc64le-linux-gnu/pkgconfig && \
            cargo build --release --target powerpc64le-unknown-linux-gnu && \
            cp target/powerpc64le-unknown-linux-gnu/release/echopulse /usr/local/bin/echopulse ;; \
        *) \
            echo "Unsupported architecture: ${TARGETARCH}"; exit 1 ;; \
    esac

FROM gcr.io/distroless/cc-debian12:latest
COPY --from=builder /usr/local/bin/echopulse /usr/local/bin/echopulse
EXPOSE 8080
USER 1001
CMD ["/usr/local/bin/echopulse"]
